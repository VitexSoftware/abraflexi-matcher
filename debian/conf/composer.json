{
  "name": "deb/abraflexi-matcher",
  "description": "Invoice Matcher for AbraFlexi written in PHP",
  "type": "project",
  "version": "0.8",
  "authors": [
    {
      "name": "Vítězslav Dvořák",
      "email": "info@vitexsoftware.cz"
    }
  ],
  "require": {
    "deb/abraflexi": "*",
    "deb/abraflexi-bricks": "*"
  },
  "autoload": {
    "psr-4": {
      "AbraFlexi\\Matcher\\": "AbraFlexi/Matcher/",
      "AbraFlexi\\Matcher\\Ui\\": "AbraFlexi/Matcher/Ui/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "/usr/share/php/EaseCore"
    },
    {
      "type": "path",
      "url": "/usr/share/php/AbraFlexi"
    },
    {
      "type": "path",
      "url": "/usr/share/php/AbraFlexiBricks"
    }
  ]
}
