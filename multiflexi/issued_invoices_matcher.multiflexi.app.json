{
  "$schema": "https://raw.githubusercontent.com/VitexSoftware/php-vitexsoftware-multiflexi-core/refs/heads/main/schema/application.json",
  "schemaVersion": "3.4.0",
  "version": "1.1.0",
  "uuid": "177888a6-56aa-4024-89ec-80743150502a",
  "name": {
    "en": "AbraFlexi Issued invoices Matcher",
    "cs": "Párovač vydaných faktur AbraFlexi"
  },
  "description": {
    "en": "Matches issued invoices in AbraFlexi.",
    "cs": "Páruje vydané faktury v systému AbraFlexi."
  },
  "author": "Vitex Software",
  "license": "MIT",
  "category": "matcher",
  "requirements": [
    "AbraFlexi"
  ],
  "tags": [
    "AbraFlexi",
    "Matcher",
    "Invoicing"
  ],
  "executable": "abraflexi-matcher-out",
  "events": {
    "consumes": {
      "bank.statement.downloaded": {
        "description": "A bank statement file was downloaded",
        "format": "file"
      }
    },
    "emits": {
      "invoice.matched": {
        "description": "An invoice was matched with a payment"
      },
      "payment.received": {
        "description": "An incoming payment was matched to a document",
        "evidence": "banka",
        "operation": "create"
      }
    }
  },
  "environment": {
    "MATCHER_LOCALIZE": {
      "type": "set",
      "description": {
        "en": "Locale for this application",
        "cs": "Jazykové nastavení aplikace"
      },
      "defval": "en_US",
      "options": [
        "en_US",
        "cs_CZ",
        "sk_SK"
      ],
      "category": "Other",
      "required": false
    },
    "EASE_LOGGER": {
      "type": "string",
      "description": {
        "en": "write log messages using",
        "cs": "Způsob zápisu logovacích zpráv"
      },
      "defval": "console|syslog",
      "required": false,
      "category": "Behavior"
    },
    "RESULT_FILE": {
      "type": "string",
      "description": {
        "en": "write output json data to",
        "cs": "Cesta k výstupnímu souboru JSON"
      },
      "defval": "transaction_report.json",
      "required": false,
      "category": "Other"
    },
    "ABRAFLEXI_COMPANY": {
      "type": "string",
      "description": "",
      "defval": "demo_de",
      "required": true,
      "category": "API"
    },
    "ABRAFLEXI_LOGIN": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Login",
        "cs": "Přihlašovací jméno do AbraFlexi"
      },
      "hint": "winstrom",
      "required": true,
      "category": "API"
    },
    "ABRAFLEXI_PASSWORD": {
      "type": "password",
      "description": {
        "en": "AbraFlexi password",
        "cs": "Heslo do AbraFlexi"
      },
      "hint": "winstrom",
      "required": true,
      "category": "API"
    },
    "ABRAFLEXI_URL": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Server URI",
        "cs": "Adresa serveru AbraFlexi"
      },
      "hint": "https://demo.flexibee.eu:5434",
      "required": true,
      "category": "API"
    },
    "MATCHER_DAYS_BACK": {
      "type": "integer",
      "description": {
        "en": "How far into the past to match invoices",
        "cs": "Jak daleko do minulosti párovat faktury"
      },
      "defval": "365",
      "required": true,
      "category": "Other"
    },
    "ABRAFLEXI_OVERPAY": {
      "type": "string",
      "description": {
        "en": "Pull overpayments from bank statements",
        "cs": "Stáhnout přeplatky z bankovních výpisů"
      },
      "hint": {
        "en": "OST. ZÁVAZKY",
        "cs": "OST. ZÁVAZKY"
      },
      "required": false,
      "category": "API"
    },
    "ABRAFLEXI_PARTIAL_MATCH": {
      "type": "bool",
      "description": {
        "en": "Settle underpaid invoices automatically instead of leaving them for manual review",
        "cs": "Automaticky spárovat nedoplatky místo ponechání k ruční kontrole"
      },
      "defval": false,
      "required": false,
      "category": "Other"
    }
  },
  "exitCodes": {
    "0": {
      "description": {
        "en": "Success",
        "cs": "Úspěch"
      },
      "severity": "success",
      "retry": false
    }
  }
}
